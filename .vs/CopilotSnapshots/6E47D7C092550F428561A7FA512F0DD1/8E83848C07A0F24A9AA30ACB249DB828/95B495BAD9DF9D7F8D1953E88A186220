<nav class="navbar">

  <!-- 🔹 Logo -->
  <div class="logo">Stationary Store</div>

  <!-- 🔹 Links -->
  <div class="nav-links">

    <!-- COMMON -->
    <a routerLink="/dashboard" routerLinkActive="active">Dashboard</a>
    
      <!-- USER -->
    <ng-container *ngIf="role === 'User'">
      <a routerLink="/request-item" routerLinkActive="active">Request Item</a>
      <a routerLink="/my-requests" routerLinkActive="active">My Requests</a>
    </ng-container>

      <!-- ADMIN -->
      <ng-container *ngIf="role === 'Admin'">
        <a routerLink="/inventory" routerLinkActive="active">Add Items</a>
        <a routerLink="/pending-requests" routerLinkActive="active">Pending Requests</a>
      </ng-container>

      <!-- ISSUER -->
      <ng-container *ngIf="role === 'Issuer'">
        <a routerLink="/approved" routerLinkActive="active">Approved</a>
        <a routerLink="/issue" routerLinkActive="active">Issue</a>
        <a routerLink="/inventory" routerLinkActive="active">Inventory</a>
      </ng-container>

      <!-- LOGOUT -->
      <button (click)="logout()">Logout</button>

  </div>
</nav>
