# ========================================
# Docker Compose / Production Environment Variables
# ========================================
# Copy this to .env and customize for your environment.
# This file should NOT be committed to version control.

# -----------------------------------------------
# DATABASE — ASP.NET Core connection string
# The double-underscore (__) maps to JSON hierarchy:
#   ConnectionStrings:DefaultConnection
# This env var overrides appsettings.json at runtime.
# -----------------------------------------------
ConnectionStrings__DefaultConnection=Host=<RDS-HOST>;Port=5432;Database=postgres;Username=postgres;Password=<PASSWORD>;Pooling=true;Minimum Pool Size=5;Maximum Pool Size=20;Connection Idle Lifetime=30;SSL Mode=Require;Trust Server Certificate=true;

# PostgreSQL (Docker Compose local dev only)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme

# Admin Seed Account
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=changeme

# ASP.NET Core Environment (Development | Production)
ASPNETCORE_ENVIRONMENT=Production

# JWT Secret Key (MUST change in production — use a long random string)
JWT_KEY=CHANGE_THIS_TO_A_LONG_RANDOM_SECRET_KEY
