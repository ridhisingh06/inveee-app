{
  "family": "inveee-app-task",
  "networkMode": "awsvpc",
  "executionRoleArn": "arn:aws:iam::396287094524:role/inveee-task-execution-role",
  "taskRoleArn": "arn:aws:iam::396287094524:role/inveee-app-task-role",
  "containerDefinitions": [
    {
      "name": "app",
      "image": "396287094524.dkr.ecr.us-east-1.amazonaws.com/inveee-app:9440b0721d260b58eff39de2d2b4d46401f9e8c0",
      "cpu": 0,
      "portMappings": [
        {
          "containerPort": 5000,
          "hostPort": 5000,
          "protocol": "tcp"
        }
      ],
      "essential": true,
      "environment": [
        {
          "name": "ConnectionStrings__DefaultConnection",
          "value": ""
        },
        { "name": "ASPNETCORE_ENVIRONMENT", "value": "Production" },
        { "name": "ASPNETCORE_URLS", "value": "http://+:5000" },
        { "name": "COMPlus_DbgMiniDumpName", "value": "/tmp/dump.%p.dmp" },
        { "name": "Jwt__Audience", "value": "invmgmt_user" },
        { "name": "COMPlus_DbgMiniDumpType", "value": "4" },
        { "name": "COMPlus_DbgEnableMiniDump", "value": "1" },
        { "name": "Jwt__Key", "value": "THIS_IS_MY_SECRET_KEY_12345_ABCDEF_2026" },
        { "name": "Jwt__Issuer", "value": "invmgmt" },
        { "name": "FRONTEND_URL", "value": "https://inveee-app.vercel.app" }
      ],
      "mountPoints": [],
      "volumesFrom": [],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/inveee-app",
          "awslogs-create-group": "true",
          "awslogs-region": "us-east-1",
          "awslogs-stream-prefix": "ecs"
        }
      },
      "healthCheck": {
        "command": [
          "CMD-SHELL",
          "curl -f http://localhost:5000/health || exit 1"
        ],
        "interval": 30,
        "timeout": 10,
        "retries": 3,
        "startPeriod": 60
      },
      "systemControls": []
    }
  ],
  "requiresCompatibilities": [
    "FARGATE"
  ],
  "cpu": "256",
  "memory": "512",
  "volumes": [],
  "placementConstraints": []
}
