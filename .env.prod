# ========================================
# Production Environment Configuration
# ========================================
# Copy this file to .env on EC2 and customize values

# -----------------------------------------------
# PostgreSQL Database
# -----------------------------------------------
POSTGRES_USER=postgres
POSTGRES_PASSWORD=YourSecurePasswordHere123!
POSTGRES_DB=postgres

# -----------------------------------------------
# ASP.NET Core Environment
# -----------------------------------------------
ASPNETCORE_ENVIRONMENT=Production

# -----------------------------------------------
# JWT Authentication
# Generate with: openssl rand -base64 32
# -----------------------------------------------
JWT_KEY=CHANGE_THIS_TO_A_LONG_RANDOM_SECRET_KEY_AT_LEAST_32_CHARS
JWT_ISSUER=invmgmt-api
JWT_AUDIENCE=invmgmt-frontend

# -----------------------------------------------
# Admin Seed Account
# -----------------------------------------------
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=AdminPassword123!

# -----------------------------------------------
# Database Connection (for direct access if needed)
# -----------------------------------------------
DB_HOST=postgres
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=YourSecurePasswordHere123!
DB_NAME=postgres

# -----------------------------------------------
# API Configuration
# -----------------------------------------------
API_URL=http://100.55.99.251:5000
